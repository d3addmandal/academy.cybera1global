# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
node_modules
.next
.env.local
.vercel
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel
.claude

# typescript
*.tsbuildinfo
next-env.d.ts

# CRM uploads/local dev seed images — production serves these from Vercel Blob only
/public/uploads/*
/public/images/*

# Local CRM data store — real per-company content (incl. admin credentials once seeded)
# lives in Vercel Blob storage in production and is never read from here there; locally
# it's your own working copy. Never commit real data here — see src/lib/seed.ts for how
# a fresh company is bootstrapped (random password, generated at runtime, not committed).
/data/*

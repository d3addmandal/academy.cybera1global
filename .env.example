# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-32-byte-hex-secret-here

# Company slug (matches the crm-db/<slug>/ prefix in Vercel Blob)
COMPANY_SLUG=cybera1

# Required in ALL environments (including local dev) — CRM data and uploaded images
# live exclusively in Vercel Blob. Get this from:
#   Vercel Dashboard → Project → Storage → Blob → (your store) → .env.local tab
# or run: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxx

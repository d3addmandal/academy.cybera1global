# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-32-byte-hex-secret-here

# Company slug (matches the data/<slug>/ directory)
COMPANY_SLUG=cybera1

# Required in production for certificate digital signing (Ed25519 keypair).
# Generate once with:
# node -e "const {publicKey,privateKey}=require('crypto').generateKeyPairSync('ed25519');console.log(privateKey.export({type:'pkcs8',format:'pem'}));console.log(publicKey.export({type:'spki',format:'pem'}))"
# Paste each PEM block as-is (including the BEGIN/END lines).
CERT_SIGNING_PRIVATE_KEY=
CERT_SIGNING_PUBLIC_KEY=
